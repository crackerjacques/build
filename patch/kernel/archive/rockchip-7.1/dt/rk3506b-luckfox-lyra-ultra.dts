/*
 * Luckfox Lyra Ultra (non-W: no WiFi/BT) on a mainline kernel.
 *
 * RK3506B / triple Cortex-A7 / 512MB DDR3 / eMMC. Minimal bring-up:
 * debug console on UART0 (0xff0a0000) and the on-board eMMC. Display,
 * Ethernet and the audio/CAN/flexbus blocks are intentionally left out
 * until their drivers land in mainline.
 */

/dts-v1/;

#include "rk3506.dtsi"

/ {
	model = "Luckfox Lyra Ultra";
	compatible = "rockchip,rk3506b-lyra-ultra", "rockchip,rk3506";

	aliases {
		serial0 = &uart0;
		mmc0 = &mmc;
	};

	chosen {
		stdout-path = "serial0:1500000n8";
	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x20000000>;
	};
};

&uart0 {
	status = "okay";
};

&mmc {
	bus-width = <4>;
	/* SDR high-speed only. DDR52 reads were corrupting at init time (fsck
	 * clean but mount EBADMSG, U-Boot "No partition table") because mainline
	 * dw_mmc-rockchip has no rk3506 delay-line tuning, so DDR's tight timing
	 * margin fails. SDR samples on one clock edge = double the margin. */
	cap-mmc-highspeed;
	non-removable;
	no-sd;
	no-sdio;
	disable-wp;
	supports-emmc;
	pinctrl-names = "default";
	pinctrl-0 = <&sdmmc_clk_pins &sdmmc_cmd_pins &sdmmc_bus4_pins>;
	status = "okay";
};

&gmac1 {
	phy-mode = "rmii";
	clock_in_out = "output";
	snps,reset-gpio = <&gpio1 RK_PD0 GPIO_ACTIVE_LOW>;
	snps,reset-active-low;
	snps,reset-delays-us = <0 20000 100000>;
	pinctrl-names = "default";
	pinctrl-0 = <&rmii1_miim_pins &rmii1_clk_pins &rmii1_rx_pins &rmii1_tx_pins>;
	phy-handle = <&phy1>;
	status = "okay";

	mdio {
		compatible = "snps,dwmac-mdio";
		#address-cells = <1>;
		#size-cells = <0>;

		phy1: ethernet-phy@1 {
			compatible = "ethernet-phy-ieee802.3-c22";
			reg = <1>;
		};
	};
};
